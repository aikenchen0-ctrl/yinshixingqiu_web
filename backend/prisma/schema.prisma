generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  BANNED
}

enum StaffRole {
  OWNER
  PARTNER
  ADMIN
  OPERATOR
}

enum GroupStatus {
  DRAFT
  ACTIVE
  HIDDEN
  CLOSED
}

enum GroupJoinType {
  FREE
  PAID
  INVITE_ONLY
}

enum BillingPeriod {
  MONTH
  QUARTER
  YEAR
  FOREVER
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  QUIT
  BANNED
}

enum JoinSource {
  DIRECT
  QR_CODE
  COUPON
  INVITE
  MANUAL
}

enum PostType {
  TOPIC
  ARTICLE
  NOTICE
  CHECKIN
  ASSIGNMENT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

enum CourseAccessType {
  FREE
  MEMBER
  PAID
}

enum CourseLessonType {
  VIDEO
  ARTICLE
}

enum CheckinChallengeStatus {
  ONGOING
  ENDED
  CLOSED
}

enum CheckinParticipantStatus {
  ACTIVE
  COMPLETED
  QUIT
}

enum CommentStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum OrderType {
  GROUP_JOIN
  GROUP_RENEWAL
  ARTICLE_UNLOCK
  REWARD
  QUESTION
  IDENTITY_MEMBER_MONTHLY
  IDENTITY_MEMBER_QUARTERLY
}

enum OrderStatus {
  PENDING
  PAID
  CLOSED
  REFUNDED
  FAILED
}

enum MallOrderStatus {
  PENDING
  PAID
  CLOSED
}

enum MallCommissionStatus {
  NONE
  PENDING
  CONFIRMED
  CANCELLED
}

enum MallProductDetailImageType {
  CAROUSEL
  PROMOTION
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentChannel {
  WECHAT
  ALIPAY
  MANUAL
  STAR_COIN
}

enum CouponType {
  PROMOTION
  RENEWAL
}

enum CouponStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum IdentityContractStatus {
  UNPAID
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ScoreEventType {
  POST_LIKE
  COMMENT_LIKE
  POST_PUBLISH
  COMMENT_PUBLISH
  CHECKIN_PUBLISH
  ASSIGNMENT_SUBMIT
  MANUAL_ADJUST
}

enum ExportTaskType {
  INCOME_REPORT
  MEMBER_REPORT
  CONTENT_REPORT
  QR_CODE_REPORT
  VIDEO_LIVE_MEMBER_LIST
}

enum ExportTaskStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
}

enum HotBoardSource {
  WEIBO
  TOUTIAO
  SOGOU
}

enum AnalyticsEventType {
  PREVIEW_VIEW
  PREVIEW_CLICK_JOIN
  JOIN_PAID
  RENEWAL_PAGE_VIEW
  RENEWAL_PAID
  APP_DOWNLOAD
}

enum AnalyticsTargetType {
  GROUP
  ORDER
  POST
  COMMENT
}

enum OutboxJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id          String     @id @default(cuid())
  mobile      String?    @unique
  unionId     String?    @unique @map("union_id")
  openId      String?    @unique @map("open_id")
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  profile      UserProfile?
  authSessions AuthSession[]
  ownedGroups  Group[]             @relation("GroupOwner")
  staffGroups  GroupStaff[]
  members      GroupMember[]
  posts        Post[]
  comments     Comment[]
  postLikes    PostLike[]
  commentLikes CommentLike[]
  orders       Order[]
  articleUnlocks ArticleUnlock[]
  mallCartItems MallCartItem[]
  mallOrders    MallOrder[]
  mallShippingAddresses MallShippingAddress[]
  mallProductReviews MallProductReview[]
  scoreLedgers MemberScoreLedger[]
  checkinChallengeParticipants CheckinChallengeParticipant[]
  notificationSubscriptions    GroupNotificationSubscription[]
  courseProgresses CourseProgress[]

  @@map("users")
}

model AuthSession {
  id           String            @id @default(cuid())
  userId       String            @map("user_id")
  sessionToken String            @unique @map("session_token")
  loginCode    String            @map("login_code")
  sessionKey   String?           @map("session_key")
  status       AuthSessionStatus @default(ACTIVE)
  expiresAt    DateTime          @map("expires_at")
  revokedAt    DateTime?         @map("revoked_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("auth_sessions")
}

model UserProfile {
  userId    String   @id @map("user_id")
  nickname  String
  avatarUrl String?  @map("avatar_url")
  wechatNo  String?  @map("wechat_no")
  city      String?
  province  String?
  bio       String?
  remark    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model Group {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  externalGroupId     String?       @unique @map("external_group_id")
  ownerUserId         String        @map("owner_user_id")
  avatarUrl           String?       @map("avatar_url")
  coverUrl            String?       @map("cover_url")
  intro               String?
  description         String?
  metadata            Json?
  joinType            GroupJoinType @default(PAID) @map("join_type")
  billingPeriod       BillingPeriod @default(YEAR) @map("billing_period")
  priceAmount         Decimal       @default(0) @map("price_amount") @db.Decimal(10, 2)
  originalPriceAmount Decimal       @default(0) @map("original_price_amount") @db.Decimal(10, 2)
  status              GroupStatus   @default(DRAFT)
  memberCount         Int           @default(0) @map("member_count")
  paidMemberCount     Int           @default(0) @map("paid_member_count")
  contentCount        Int           @default(0) @map("content_count")
  publishedAt         DateTime?     @map("published_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  owner             User                          @relation("GroupOwner", fields: [ownerUserId], references: [id])
  permissionPolicy  GroupPermissionPolicy?
  staffs            GroupStaff[]
  members           GroupMember[]
  posts             Post[]
  orders            Order[]
  coupons           Coupon[]
  promotionChannels PromotionChannel[]
  notifications     GroupNotification[]
  notificationSubscriptions GroupNotificationSubscription[]
  renewalSetting    RenewalSetting?
  renewalTemplates  RenewalNotificationTemplate[]
  scoreboardSetting ScoreboardSetting?
  scoreRules        ScoreRule[]
  scoreLedgers      MemberScoreLedger[]
  incomeStats       GroupIncomeDailyStat[]
  promotionStats    GroupPromotionDailyStat[]
  memberStats       GroupMemberDailyStat[]
  contentStats      GroupContentDailyStat[]
  renewalStats      GroupRenewalDailyStat[]
  exportTasks       ExportTask[]
  identityContracts IdentityMemberContract[]
  checkinChallenges CheckinChallenge[]
  columns           Column[]
  articleUnlocks    ArticleUnlock[]
  courses           Course[]
  mallCategories    MallCategory[]
  mallProducts      MallProduct[]
  mallProductDetailImages MallProductDetailImage[]
  mallOrders        MallOrder[]

  @@index([ownerUserId])
  @@index([status])
  @@map("groups")
}

model GroupPermissionPolicy {
  id                          String   @id @default(cuid())
  groupId                     String   @unique @map("group_id")
  partnerCanViewDashboard     Boolean  @default(true) @map("partner_can_view_dashboard")
  adminCanViewDashboard       Boolean  @default(true) @map("admin_can_view_dashboard")
  partnerCanViewIncome        Boolean  @default(true) @map("partner_can_view_income")
  adminCanViewIncome          Boolean  @default(true) @map("admin_can_view_income")
  partnerCanViewMemberContact Boolean  @default(true) @map("partner_can_view_member_contact")
  adminCanViewMemberContact   Boolean  @default(true) @map("admin_can_view_member_contact")
  partnerCanViewWeeklyReport  Boolean  @default(true) @map("partner_can_view_weekly_report")
  adminCanViewWeeklyReport    Boolean  @default(true) @map("admin_can_view_weekly_report")
  allowStarCoinJoin           Boolean  @default(false) @map("allow_star_coin_join")
  allowStarCoinRenewal        Boolean  @default(false) @map("allow_star_coin_renewal")
  allowVirtualPayJoin         Boolean  @default(false) @map("allow_virtual_pay_join")
  allowVirtualPayRenewal      Boolean  @default(false) @map("allow_virtual_pay_renewal")
  allowJoin                   Boolean  @default(true) @map("allow_join")
  needExamine                 Boolean  @default(false) @map("need_examine")
  allowPreview                Boolean  @default(true) @map("allow_preview")
  allowSearch                 Boolean  @default(true) @map("allow_search")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id])

  @@map("group_permission_policies")
}

model GroupStaff {
  id        String    @id @default(cuid())
  groupId   String    @map("group_id")
  userId    String    @map("user_id")
  role      StaffRole
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("group_staffs")
}

model GroupMember {
  id            String       @id @default(cuid())
  groupId       String       @map("group_id")
  userId        String       @map("user_id")
  memberNo      Int?         @map("member_no")
  status        MemberStatus @default(ACTIVE)
  joinSource    JoinSource   @default(DIRECT) @map("join_source")
  isPaid        Boolean      @default(false) @map("is_paid")
  joinedAt      DateTime     @default(now()) @map("joined_at")
  firstJoinedAt DateTime?    @map("first_joined_at")
  expireAt      DateTime?    @map("expire_at")
  lastActiveAt  DateTime?    @map("last_active_at")
  renewTimes    Int          @default(0) @map("renew_times")
  phone         String?
  wechatNo      String?      @map("wechat_no")
  sourceOrderId String?      @map("source_order_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  group        Group               @relation(fields: [groupId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
  couponClaims CouponClaim[]
  scoreLedgers MemberScoreLedger[]

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@index([expireAt])
  @@map("group_members")
}

model Post {
  id           String     @id @default(cuid())
  groupId      String     @map("group_id")
  authorUserId String     @map("author_user_id")
  type         PostType   @default(TOPIC)
  status       PostStatus @default(PUBLISHED)
  title        String?
  summary      String?
  contentText  String     @map("content_text")
  attachments  Json?
  metadata     Json?
  readingCount Int        @default(0) @map("reading_count")
  likeCount    Int        @default(0) @map("like_count")
  commentCount Int        @default(0) @map("comment_count")
  isPinned     Boolean    @default(false) @map("is_pinned")
  isEssence    Boolean    @default(false) @map("is_essence")
  publishedAt  DateTime?  @map("published_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  group    Group     @relation(fields: [groupId], references: [id])
  author   User      @relation(fields: [authorUserId], references: [id])
  comments Comment[]
  likes    PostLike[]
  articleUnlocks ArticleUnlock[]

  @@index([groupId, type, status])
  @@index([publishedAt])
  @@map("posts")
}

model Course {
  id          String           @id @default(cuid())
  groupId     String?          @map("group_id")
  title       String
  subtitle    String?
  summary     String?
  category    String?
  difficulty  String?
  coverImage  String?          @map("cover_image")
  tags        Json?
  status      CourseStatus     @default(DRAFT)
  accessType  CourseAccessType @default(FREE) @map("access_type")
  priceAmount Decimal          @default(0) @map("price_amount") @db.Decimal(10, 2)
  sortOrder   Int              @default(0) @map("sort_order")
  publishedAt DateTime?        @map("published_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  group      Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  lessons    CourseLesson[]
  progresses CourseProgress[]

  @@index([groupId, status, sortOrder])
  @@index([status, sortOrder])
  @@map("courses")
}

model CourseLesson {
  id           String           @id @default(cuid())
  courseId     String           @map("course_id")
  title        String
  summary      String?
  lessonType   CourseLessonType @default(ARTICLE) @map("lesson_type")
  videoUrl     String?          @map("video_url")
  durationText String?          @map("duration_text")
  contentText  String?          @map("content_text") @db.Text
  richContent  String?          @map("rich_content") @db.Text
  coverImage   String?          @map("cover_image")
  posterImage  String?          @map("poster_image")
  images       Json?
  isTrial      Boolean          @default(false) @map("is_trial")
  sortOrder    Int              @default(0) @map("sort_order")
  status       CourseStatus     @default(DRAFT)
  publishedAt  DateTime?        @map("published_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progresses CourseProgress[]

  @@index([courseId, status, sortOrder])
  @@map("course_lessons")
}

model CourseProgress {
  id              String    @id @default(cuid())
  courseId        String    @map("course_id")
  lessonId        String    @map("lesson_id")
  userId          String    @map("user_id")
  isCompleted     Boolean   @default(false) @map("is_completed")
  lastPositionSec Int       @default(0) @map("last_position_sec")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
  @@index([courseId, userId])
  @@map("course_progresses")
}

model CheckinChallenge {
  id             String                 @id @default(cuid())
  groupId        String                 @map("group_id")
  title          String
  description    String
  status         CheckinChallengeStatus @default(ONGOING)
  dayCount       Int                    @default(21) @map("day_count")
  validityText   String                 @default("长期有效") @map("validity_text")
  heroColor      String                 @default("teal") @map("hero_color")
  sortOrder      Int                    @default(0) @map("sort_order")
  joinedCount    Int                    @default(0) @map("joined_count")
  checkinCount   Int                    @default(0) @map("checkin_count")
  completedCount Int                    @default(0) @map("completed_count")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  group        Group                       @relation(fields: [groupId], references: [id])
  participants CheckinChallengeParticipant[]

  @@index([groupId, status, sortOrder])
  @@map("checkin_challenges")
}

model CheckinChallengeParticipant {
  id          String                   @id @default(cuid())
  challengeId String                   @map("challenge_id")
  userId      String                   @map("user_id")
  status      CheckinParticipantStatus @default(ACTIVE)
  joinedAt    DateTime                 @default(now()) @map("joined_at")
  completedAt DateTime?                @map("completed_at")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  challenge CheckinChallenge @relation(fields: [challengeId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@unique([challengeId, userId])
  @@index([challengeId, status])
  @@index([userId, status])
  @@map("checkin_challenge_participants")
}

model Comment {
  id          String        @id @default(cuid())
  postId      String        @map("post_id")
  userId      String        @map("user_id")
  parentId    String?       @map("parent_id")
  status      CommentStatus @default(PUBLISHED)
  contentText String        @map("content_text")
  attachments Json?
  likeCount   Int           @default(0) @map("like_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  post    Post      @relation(fields: [postId], references: [id])
  user    User      @relation(fields: [userId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId, createdAt])
  @@map("comments")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("post_likes")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("comment_likes")
}

model Order {
  id                 String        @id @default(cuid())
  orderNo            String        @unique @map("order_no")
  groupId            String?       @map("group_id")
  userId             String        @map("user_id")
  type               OrderType
  status             OrderStatus   @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID) @map("payment_status")
  amount             Decimal       @db.Decimal(10, 2)
  netAmount          Decimal       @default(0) @map("net_amount") @db.Decimal(10, 2)
  originalAmount     Decimal       @default(0) @map("original_amount") @db.Decimal(10, 2)
  discountAmount     Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  couponId           String?       @map("coupon_id")
  promotionChannelId String?       @map("promotion_channel_id")
  expireAt           DateTime?     @map("expire_at")
  paidAt             DateTime?     @map("paid_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  group            Group?            @relation(fields: [groupId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  coupon           Coupon?           @relation(fields: [couponId], references: [id])
  promotionChannel PromotionChannel? @relation(fields: [promotionChannelId], references: [id])
  paymentRecords   PaymentRecord[]
  articleUnlock    ArticleUnlock?
  couponClaims     CouponClaim[]

  @@index([groupId, type, status])
  @@map("orders")
}

model ArticleUnlock {
  id         String   @id @default(cuid())
  articleId  String   @map("article_id")
  groupId    String   @map("group_id")
  userId     String   @map("user_id")
  orderId    String   @unique @map("order_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  article Post  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@index([groupId, unlockedAt])
  @@index([userId, unlockedAt])
  @@map("article_unlocks")
}

model MallCategory {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  name      String
  slug      String?
  sortOrder Int      @default(0) @map("sort_order")
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group    Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  products MallProduct[]

  @@unique([groupId, name])
  @@unique([groupId, slug])
  @@index([groupId, isEnabled, sortOrder])
  @@map("mall_categories")
}

model MallProduct {
  id             String   @id @default(cuid())
  groupId        String   @map("group_id")
  categoryId     String   @map("category_id")
  title          String
  subtitle       String?
  coverImageUrl  String?  @map("cover_image_url")
  price          Decimal  @db.Decimal(10, 2)
  originalPrice  Decimal  @default(0) @map("original_price") @db.Decimal(10, 2)
  stock          Int      @default(0)
  isOnSale       Boolean  @default(true) @map("is_on_sale")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  category   MallCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cartItems  MallCartItem[]
  orderItems MallOrderItem[]
  reviews    MallProductReview[]
  detailImages MallProductDetailImage[]

  @@index([groupId, isOnSale, sortOrder])
  @@index([categoryId, isOnSale, sortOrder])
  @@map("mall_products")
}

model MallProductDetailImage {
  id          String   @id @default(cuid())
  groupId     String   @map("group_id")
  productId   String   @map("product_id")
  mediaType   MallProductDetailImageType @default(PROMOTION) @map("media_type")
  imageUrl    String   @map("image_url")
  title       String?
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group   Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product MallProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([groupId, productId, isEnabled, sortOrder])
  @@index([productId, isEnabled, sortOrder])
  @@map("mall_product_detail_images")
}

model MallProductReview {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  userId      String   @map("user_id")
  rating      Int      @default(5)
  content     String
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product MallProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, createdAt])
  @@map("mall_product_reviews")
}

model MallShippingAddress {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  recipientName String   @map("recipient_name")
  phone         String
  province      String
  city          String
