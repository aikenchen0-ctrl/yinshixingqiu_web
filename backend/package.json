{
  "name": "xueyin-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "node scripts/seedDemoData.js",
    "db:seed-mall": "node scripts/seedMallDemoData.js",
    "db:backfill-owner-members": "node scripts/backfillOwnerMemberships.js",
    "db:delete-group": "node scripts/deleteGroup.js",
    "start": "node src/server.js",
    "start:no-db": "node scripts/startWithoutDb.js",
    "start:prod": "node src/server.js",
    "verify:join-flow": "node scripts/verifyJoinFlow.js",
    "deploy:boss:prepare": "bash deploy/prepare-openwebui-hermes-env.sh",
    "deploy:boss:check": "bash deploy/check-openwebui-hermes.sh",
    "deploy:boss:prepare:windows": "powershell -ExecutionPolicy Bypass -File deploy/prepare-openwebui-hermes-env.ps1",
    "deploy:boss:start:webui:windows": "powershell -ExecutionPolicy Bypass -File deploy/start-openwebui-hermes-windows.ps1"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "dotenv": "^17.3.1",
    "prisma": "^6.18.0"
  }
}
