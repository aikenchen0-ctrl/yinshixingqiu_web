<view class="nav {{extClass}}">
  <view
    class="nav-inner {{ios ? 'ios' : 'android'}}"
    style="color: {{color}}; background: {{background}}; {{displayStyle}}; {{innerPaddingRight}}; {{safeAreaTop}};"
  >
    <view class="nav-left" style="{{leftWidth}}">
      <block wx:if="{{back || homeButton}}">
        <block wx:if="{{back}}">
          <view class="nav-buttons nav-buttons-back">
            <view
              bindtap="back"
              class="nav-btn-back-wrapper"
              hover-class="nav-active"
              hover-stay-time="100"
              aria-role="button"
              aria-label="返回"
            >
              <view class="nav-btn-back"></view>
            </view>
          </view>
        </block>
        <block wx:if="{{homeButton}}">
          <view class="nav-buttons nav-buttons-home">
            <view
              bindtap="home"
              class="nav-btn-home-wrapper"
              hover-class="nav-active"
              aria-role="button"
              aria-label="首页"
            >
              <view class="nav-btn-home"></view>
            </view>
          </view>
        </block>
      </block>
      <block wx:else>
        <slot name="left"></slot>
      </block>
    </view>

    <view class="nav-center">
      <view wx:if="{{loading}}" class="nav-loading" aria-role="alert">
        <view class="nav-spinner" aria-role="img" aria-label="加载中"></view>
      </view>
      <block wx:if="{{title}}">
        <text class="nav-title">{{title}}</text>
      </block>
      <block wx:else>
        <slot name="center"></slot>
      </block>
    </view>

    <view class="nav-right">
      <slot name="right"></slot>
    </view>
  </view>
  <view class="nav-line"></view>
</view>
