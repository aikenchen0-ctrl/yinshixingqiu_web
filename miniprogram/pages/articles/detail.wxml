<navigation-bar
  title="详情"
  back="{{true}}"
  color="#22160d"
  background="#ffffff"
></navigation-bar>

<scroll-view class="article-detail-page" scroll-y="{{true}}">
  <view class="article-detail-shell">
    <view class="article-author">
      <image class="article-author-avatar" src="{{article.authorAvatar}}" mode="aspectFill"></image>
      <view class="article-author-copy">
        <view class="article-author-head">
          <text wx:if="{{article.authorTag}}" class="article-author-tag">{{article.authorTag}}</text>
          <text class="article-author-name">{{article.author}}</text>
        </view>
        <text class="article-author-time">{{article.time}}</text>
      </view>
    </view>

    <text class="article-title">{{article.title}}</text>
    <text class="article-summary">{{article.summary}}</text>

    <image class="article-cover" src="{{article.coverImage}}" mode="aspectFill"></image>

    <view class="article-action-row">
      <view class="article-action-item">
        <view class="article-icon article-icon-like"></view>
        <text class="article-action-count">{{article.likeCount}}</text>
      </view>
      <view class="article-action-item">
        <view class="article-icon article-icon-comment"></view>
        <text class="article-action-count">{{article.commentCount}}</text>
      </view>
      <text class="article-hidden-hint">{{article.hiddenHint}}</text>
    </view>

    <button class="article-more-button" bindtap="onOpenMoreContent">{{article.actionText}}</button>

    <view class="article-divider-title">
      <view class="article-divider-line"></view>
      <text class="article-divider-text">{{article.recommendTitle}}</text>
      <view class="article-divider-line"></view>
    </view>

    <view
      class="article-planet-card"
      data-id="{{article.planetCard.id}}"
      data-name="{{article.planetCard.name}}"
      data-creator="{{article.planetCard.creator || article.author}}"
      bindtap="onPlanetCardTap"
    >
      <image class="article-planet-avatar" src="{{article.planetCard.avatar}}" mode="aspectFill"></image>
      <view class="article-planet-copy">
        <view class="article-planet-head">
          <text class="article-planet-name">{{article.planetCard.name}}</text>
          <text class="article-planet-enter">进入</text>
        </view>
        <text class="article-planet-intro">{{article.planetCard.intro}}</text>
        <text class="article-planet-meta">{{article.planetCard.meta}}</text>
      </view>
    </view>
  </view>
</scroll-view>
