<navigation-bar
  title=""
  back="{{true}}"
  color="#222222"
  background="#ffffff"
></navigation-bar>

<scroll-view class="page columns-page" scroll-y="{{true}}">
  <view class="columns-head-card">
    <view class="columns-head-icon"></view>
    <view class="columns-head-copy">
      <view class="columns-title-row">
        <text class="columns-title">程序员创业之路</text>
        <text class="columns-title-suffix">✚ 20133213</text>
      </view>
      <text class="columns-subtitle">共 20 个专栏</text>
    </view>
  </view>

  <view class="columns-list">
    <view class="columns-group" wx:for="{{columns}}" wx:for-item="column" wx:key="id">
      <view class="columns-row" data-id="{{column.id}}" bindtap="onToggleColumn">
        <view class="columns-row-left">
          <view class="columns-row-icon"></view>
          <text class="columns-row-title">{{column.title}}</text>
          <text class="columns-row-count">({{column.count}})</text>
        </view>
        <text class="columns-row-arrow {{column.expanded ? 'columns-row-arrow-expanded' : ''}}">⌃</text>
      </view>

      <view wx:if="{{column.expanded && column.items.length}}" class="columns-panel">
        <view wx:for="{{column.items}}" wx:for-item="entry" wx:key="*this" class="columns-panel-item">
          <text class="columns-panel-dot">•</text>
          <text class="columns-panel-text">{{entry}}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
