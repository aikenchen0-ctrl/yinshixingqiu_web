<navigation-bar
  title="详情"
  back="{{true}}"
  color="#222222"
  background="#ffffff"
></navigation-bar>

<view class="page planet-post-page">
  <view class="planet-post-head">
    <view class="planet-post-avatar"></view>
    <view class="planet-post-author">
      <text class="planet-post-name">{{post.displayAuthor}}</text>
      <text class="planet-post-time">{{post.time}}</text>
    </view>
  </view>

  <text wx:if="{{post.title}}" class="planet-post-title">{{post.title}}</text>

  <rich-text wx:if="{{post.isRichContent}}" class="planet-post-rich-text" nodes="{{post.richContent}}"></rich-text>

  <view wx:if="{{post.images.length}}" class="planet-post-images">
    <image
      wx:for="{{post.images}}"
      wx:key="*this"
      class="planet-post-image"
      src="{{item}}"
      mode="aspectFill"
    ></image>
  </view>

  <view class="planet-post-tools">
    <view wx:if="{{canEdit}}" class="planet-post-tool" bindtap="onEditPost">
      <view class="tool-icon tool-icon-edit"></view>
      <text class="planet-post-tool-text">编辑主题</text>
    </view>
    <button class="planet-post-tool planet-post-tool-button" open-type="share">
      <view class="tool-icon tool-icon-share"></view>
      <text class="planet-post-tool-text">分享好友</text>
    </button>
    <view class="planet-post-tool" bindtap="onGeneratePoster">
      <view class="tool-icon tool-icon-generate"></view>
      <text class="planet-post-tool-text">生成长图</text>
    </view>
  </view>

  <view class="planet-post-comment-list">
    <view wx:if="{{comments.length}}" class="planet-post-comment-section">
      <text class="planet-post-comment-title">全部观点 {{comments.length}}</text>
      <view wx:for="{{comments}}" wx:key="id" class="planet-post-comment-item">
        <view class="planet-post-comment-head">
          <text class="planet-post-comment-author">{{item.author}}</text>
          <text class="planet-post-comment-time">{{item.time}}</text>
        </view>
        <text class="planet-post-comment-content">{{item.content}}</text>
        <view
          class="planet-post-comment-like {{item.liked ? 'planet-post-comment-like-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCommentLikeTap"
        >
          <view class="feed-icon-like"></view>
          <text>赞{{item.likeCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="planet-post-comment-bar">
    <input
      class="planet-post-comment-input"
      type="text"
      confirm-type="send"
      placeholder="写下你的观点..."
      placeholder-class="planet-post-comment-placeholder"
      value="{{commentInput}}"
      bindinput="onCommentInput"
      bindconfirm="onCommentConfirm"
      cursor-spacing="24"
      adjust-position="{{false}}"
    />
    <view class="planet-post-comment-submit" bindtap="onCommentConfirm">发送</view>
    <view
      class="planet-post-like {{post.liked ? 'planet-post-like-active' : ''}} {{!canLike ? 'planet-post-like-disabled' : ''}}"
      bindtap="onLikeTap"
    >
      <view class="feed-icon-like"></view>
      <text>赞{{post.likeCount}}</text>
    </view>
  </view>
</view>
