<navigation-bar
  title="详情"
  back="{{true}}"
  color="#222222"
  background="#ffffff"
></navigation-bar>

<view class="page planet-post-page">
  <view class="planet-post-head">
    <view class="planet-post-avatar {{!post.avatar ? 'planet-post-avatar-fallback' : ''}}">
      <image wx:if="{{post.avatar}}" class="planet-post-avatar-image" src="{{post.avatar}}" mode="aspectFill" binderror="onPostAvatarError"></image>
      <text wx:else class="planet-post-avatar-fallback-text">mo</text>
    </view>
    <view class="planet-post-author">
      <text class="planet-post-name">{{post.displayAuthor}}</text>
      <text class="planet-post-time">{{post.time}}</text>
    </view>
  </view>

  <view wx:if="{{moderationNotice.visible}}" class="planet-post-moderation planet-post-moderation-{{moderationNotice.tone}}">
    <text class="planet-post-moderation-title">{{moderationNotice.title}}</text>
    <text wx:if="{{moderationNotice.meta}}" class="planet-post-moderation-meta">{{moderationNotice.meta}}</text>
    <text class="planet-post-moderation-text">{{moderationNotice.message}}</text>
  </view>

  <text wx:if="{{post.title}}" class="planet-post-title">{{post.title}}</text>

  <view wx:if="{{post.hiddenHint}}" class="planet-post-access-row">
    <text class="planet-post-access-chip {{post.accessType === 'paid' ? 'planet-post-access-chip-paid' : ''}}">
      {{post.hiddenHint}}
    </text>
    <text wx:if="{{post.showPaywallCard}}" class="planet-post-access-price">{{post.priceLabel}}</text>
  </view>

  <rich-text wx:if="{{post.isRichContent}}" class="planet-post-rich-text" nodes="{{post.richContent}}"></rich-text>

  <view wx:if="{{post.showPaywallCard}}" class="planet-post-paywall-card">
    <view class="planet-post-paywall-copy">
      <text class="planet-post-paywall-badge">付费全文</text>
      <text class="planet-post-paywall-title">{{post.paywallTitle}}</text>
      <text class="planet-post-paywall-subtitle">{{post.paywallSubtitle}}</text>
    </view>
    <button class="planet-post-paywall-button" bindtap="onUnlockArticleTap">{{post.paywallButtonText}}</button>
  </view>

  <view wx:if="{{post.videos.length}}" class="planet-post-video-list">
    <view wx:for="{{post.videos}}" wx:key="url" class="planet-post-video-card">
      <video
        class="planet-post-video"
        src="{{item.url}}"
        poster="{{item.poster}}"
        controls="{{true}}"
        show-center-play-btn="{{true}}"
        enable-progress-gesture="{{true}}"
        object-fit="contain"
      ></video>
      <view wx:if="{{item.name || item.sizeText}}" class="planet-post-video-copy">
        <text wx:if="{{item.name}}" class="planet-post-video-name">{{item.name}}</text>
        <text wx:if="{{item.sizeText}}" class="planet-post-video-meta">{{item.sizeText}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{post.images.length}}" class="planet-post-images">
    <image
      wx:for="{{post.displayImages}}"
      wx:key="*this"
      class="planet-post-image"
      src="{{item}}"
      mode="aspectFill"
      lazy-load="true"
    ></image>
  </view>

  <view wx:if="{{post.files.length}}" class="planet-post-file-list">
    <view
      wx:for="{{post.files}}"
      wx:key="url"
      class="planet-post-file-item"
      data-url="{{item.url}}"
      data-name="{{item.name}}"
      bindtap="onOpenAttachment"
    >
      <view class="planet-post-file-icon">文</view>
      <view class="planet-post-file-copy">
        <text class="planet-post-file-name">{{item.name}}</text>
        <text wx:if="{{item.sizeText}}" class="planet-post-file-meta">{{item.sizeText}}</text>
      </view>
      <text class="planet-post-file-arrow">></text>
    </view>
  </view>

  <view class="planet-post-tools">
    <view wx:if="{{canEdit}}" class="planet-post-tool" bindtap="onEditPost">
      <view class="tool-icon tool-icon-edit"></view>
      <text class="planet-post-tool-text">编辑主题</text>
    </view>
    <button class="planet-post-tool planet-post-tool-button" open-type="share">
      <view class="tool-icon tool-icon-share"></view>
      <text class="planet-post-tool-text">分享好友</text>
    </button>
    <view class="planet-post-tool" bindtap="onGeneratePoster">
      <view class="tool-icon tool-icon-generate"></view>
      <text class="planet-post-tool-text">生成长图</text>
    </view>
  </view>

  <view wx:if="{{canReport}}" class="planet-post-secondary-actions">
    <view class="planet-post-secondary-link" bindtap="onReportPost">
      <text class="planet-post-secondary-link-text">{{reporting ? '投诉提交中...' : '投诉主题'}}</text>
    </view>
  </view>

  <view wx:if="{{showJoinPlanetEntry}}" class="planet-post-join-card">
    <view class="planet-post-join-badge">精华来自该星球</view>
    <view class="planet-post-join-main">
      <image
        wx:if="{{joinPlanetCard.avatarImageUrl}}"
        class="planet-post-join-avatar"
        src="{{joinPlanetCard.avatarImageUrl}}"
        mode="aspectFill"
      ></image>
      <view wx:else class="planet-post-join-avatar planet-post-join-avatar-fallback">
        <text class="planet-post-join-avatar-text">{{joinPlanetCard.initial}}</text>
      </view>
      <view class="planet-post-join-copy">
        <text class="planet-post-join-title">{{joinPlanetCard.planetName}}</text>
        <text wx:if="{{joinPlanetCard.metaText}}" class="planet-post-join-meta">{{joinPlanetCard.metaText}}</text>
        <text class="planet-post-join-desc">加入后可继续查看更多精华、主题和互动内容</text>
      </view>
    </view>
    <view class="planet-post-join-footer">
      <view class="planet-post-join-action" bindtap="onJoinPlanetTap">加入这个星球</view>
    </view>
  </view>

  <view class="planet-post-comment-list">
    <view wx:if="{{comments.length}}" class="planet-post-comment-section">
      <text class="planet-post-comment-title">全部观点 {{comments.length}}</text>
      <view wx:for="{{comments}}" wx:key="id" class="planet-post-comment-item">
        <view class="planet-post-comment-head">
          <text class="planet-post-comment-author">{{item.author}}</text>
          <text class="planet-post-comment-time">{{item.time}}</text>
        </view>
        <text class="planet-post-comment-content">{{item.content}}</text>
        <view
          class="planet-post-comment-like {{item.liked ? 'planet-post-comment-like-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCommentLikeTap"
        >
          <view class="feed-icon-like"></view>
          <text>赞{{item.likeCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="planet-post-comment-bar">
    <input
      class="planet-post-comment-input"
      type="text"
      confirm-type="send"
      placeholder="写下你的观点..."
      placeholder-class="planet-post-comment-placeholder"
      value="{{commentInput}}"
      bindinput="onCommentInput"
      bindconfirm="onCommentConfirm"
      cursor-spacing="24"
      adjust-position="{{false}}"
    />
    <view class="planet-post-comment-submit" bindtap="onCommentConfirm">发送</view>
    <view
      class="planet-post-like {{post.liked ? 'planet-post-like-active' : ''}} {{!canLike ? 'planet-post-like-disabled' : ''}}"
      bindtap="onLikeTap"
    >
      <view class="feed-icon-like"></view>
      <text>赞{{post.likeCount}}</text>
    </view>
  </view>
</view>
