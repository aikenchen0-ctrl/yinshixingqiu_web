<navigation-bar
  title="知识星球"
  back="{{true}}"
  back-url="/pages/index/index"
  color="#22160d"
  background="#ffffff"
></navigation-bar>

<view class="page planet-list-page">
  <view class="planet-list-shell">
    <view class="planet-search-box">
      <text class="planet-search-icon">⌕</text>
      <input
        class="planet-search-input"
        placeholder="搜索星球"
        placeholder-class="planet-search-placeholder"
        value="{{searchValue}}"
        bindinput="onSearchInput"
      />
    </view>

    <block wx:if="{{searchValue}}">
      <view class="planet-list">
        <view
          class="planet-row"
          wx:for="{{searchResults}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-creator="{{item.ownerName}}"
          data-joined="{{item.joined}}"
          bindtap="onPlanetTap"
        >
          <view class="planet-row-left">
            <view class="planet-avatar {{item.avatarClass}}">
              <text class="planet-avatar-text">{{item.name.slice(0, 1)}}</text>
            </view>
            <text class="planet-name">{{item.name}}</text>
          </view>

          <view class="planet-row-right">
            <text wx:if="{{item.badge}}" class="planet-badge">{{item.badge}}</text>
            <text class="planet-arrow">›</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!searchResults.length}}" class="planet-empty-state">
        <text class="planet-empty-text">没有找到匹配的星球</text>
      </view>
    </block>

    <block wx:else>
      <view wx:if="{{joinedPlanets.length}}" class="planet-section planet-section-first">
        <text class="planet-section-title">我加入的星球</text>
        <view class="planet-list planet-list-subsection">
          <view
            class="planet-row"
            wx:for="{{joinedPlanets}}"
            wx:key="id"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            data-creator="{{item.ownerName}}"
            data-joined="{{item.joined}}"
            bindtap="onPlanetTap"
          >
            <view class="planet-row-left">
              <view class="planet-avatar {{item.avatarClass}}">
                <text class="planet-avatar-text">{{item.name.slice(0, 1)}}</text>
              </view>
              <text class="planet-name">{{item.name}}</text>
            </view>

            <view class="planet-row-right">
              <text wx:if="{{item.badge}}" class="planet-badge">{{item.badge}}</text>
              <text class="planet-arrow">›</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{userPlanets.length}}" class="planet-section">
        <text class="planet-section-title">我的星球</text>
        <view class="planet-list planet-list-subsection">
          <view
            class="planet-row"
            wx:for="{{userPlanets}}"
            wx:key="id"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            data-creator="{{item.ownerName}}"
            data-joined="{{item.joined}}"
            bindtap="onPlanetTap"
          >
            <view class="planet-row-left">
              <view class="planet-avatar {{item.avatarClass}}">
                <text class="planet-avatar-text">{{item.name.slice(0, 1)}}</text>
              </view>
              <text class="planet-name">{{item.name}}</text>
            </view>

            <view class="planet-row-right">
              <text wx:if="{{item.badge}}" class="planet-badge">{{item.badge}}</text>
              <text class="planet-arrow">›</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{!joinedPlanets.length && !userPlanets.length}}" class="planet-empty-state">
        <text class="planet-empty-text">你还没有加入或创建任何星球</text>
      </view>
    </block>

    <view class="planet-create-card">
      <view class="planet-create-shape planet-create-shape-left"></view>
      <view class="planet-create-shape planet-create-shape-right"></view>
      <text class="planet-create-text">创建你的专属星球，连接一千位铁杆粉丝</text>
      <button class="planet-create-button" bindtap="goCreate">+创建星球</button>
    </view>
  </view>

  <planet-bottom-nav active-key="planet" bindchange="onPlanetTabChange"></planet-bottom-nav>
</view>
