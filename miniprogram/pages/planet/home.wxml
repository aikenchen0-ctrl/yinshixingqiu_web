<navigation-bar
  title="{{isJoined ? '' : '饮视星球'}}"
  back="{{true}}"
  color="{{isJoined ? '#ffffff' : '#22160d'}}"
  background="{{isJoined ? 'linear-gradient(135deg, #6f8692 0%, #7d8f97 35%, #8f8a74 100%)' : '#ffffff'}}"
></navigation-bar>

<block wx:if="{{isJoined}}">
  <scroll-view class="planet-joined-page" scroll-y="{{true}}" bindtap="onCloseFeedMenu">
    <view class="planet-home-hero">
      <view class="planet-home-hero-mask"></view>
      <view class="planet-home-header">
        <view class="planet-home-avatar planet-avatar-frame {{avatarClass}}">
          <image wx:if="{{avatarImageUrl}}" class="planet-home-avatar-image" src="{{avatarImageUrl}}" mode="aspectFill"></image>
          <text wx:else class="planet-home-avatar-text">{{planetName.slice(0, 1) || '星'}}</text>
        </view>
        <view class="planet-home-copy">
          <text class="planet-home-name">{{planetName}}</text>
          <text class="planet-home-meta">{{ownerName}} 创建</text>
        </view>
      </view>

      <view class="planet-home-actions">
        <view class="planet-home-action" data-key="checkin" bindtap="onActionTap">
          <view class="planet-home-action-icon icon-calendar"></view>
          <text class="planet-home-action-label">打卡</text>
        </view>
        <view class="planet-home-action" data-key="columns" bindtap="onActionTap">
          <view class="planet-home-action-icon icon-stack"></view>
          <text class="planet-home-action-label">专栏</text>
        </view>
        <view class="planet-home-action" data-key="settings" bindtap="onActionTap">
          <view class="planet-home-action-icon icon-gear"></view>
          <text class="planet-home-action-label">设置</text>
        </view>
      </view>
    </view>

    <view class="planet-home-body">
      <view wx:if="{{showRenewalEntry}}" class="planet-home-renewal-wrap">
        <view class="planet-renewal-card">
          <view class="planet-renewal-copy">
            <text class="planet-renewal-badge">{{renewalBadgeText}}</text>
            <text class="planet-renewal-title">{{renewalTitle}}</text>
            <text class="planet-renewal-hint">{{renewalHint}}</text>
            <view class="planet-renewal-price-row">
              <text class="planet-renewal-price">{{renewalPriceText}}</text>
              <text wx:if="{{renewalOriginalPriceText}}" class="planet-renewal-original">{{renewalOriginalPriceText}}</text>
              <text wx:if="{{renewalDiscountText}}" class="planet-renewal-discount">{{renewalDiscountText}}</text>
            </view>
          </view>
          <button class="planet-renewal-button" loading="{{joinLoading}}" disabled="{{joinLoading}}" bindtap="onRenewTap">{{renewalActionText}}</button>
        </view>
      </view>

      <scroll-view
        wx:if="{{featureCards.length}}"
        class="planet-home-feature-row"
        scroll-x="{{true}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
      >
        <view
          wx:for="{{featureCards}}"
          wx:key="key"
          class="planet-home-feature-card planet-home-feature-card-{{item.key}}"
          data-key="{{item.key}}"
          bindtap="onFeatureCardTap"
        >
          <view class="planet-home-feature-arrow"></view>
          <text class="planet-home-feature-title">{{item.title}}</text>
          <text class="planet-home-feature-subtitle">{{item.subtitle}}</text>
          <text wx:if="{{item.accentLabel}}" class="planet-home-feature-accent">{{item.accentLabel}}</text>
        </view>
      </scroll-view>

      <view class="planet-home-tab-row">
        <view
          class="planet-home-tab {{activeTab === item.key ? 'planet-home-tab-active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="onTabChange"
        >
          {{item.label}}
        </view>
        <view class="planet-home-list-switch">
          <view class="switch-line"></view>
          <view class="switch-line switch-line-short"></view>
          <view class="switch-dot"></view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'latest'}}" class="planet-feed-list">
        <block wx:if="{{showNotices}}">
          <view
            class="planet-pinned-row"
            wx:for="{{pinnedList}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onPinnedTap"
          >
            <view class="planet-pinned-badge">
              <text class="planet-notice-tag">置顶</text>
              <text wx:if="{{item.prefix}}" class="planet-pinned-prefix">{{item.prefix}}</text>
            </view>
            <text class="planet-notice-text">{{item.title}}</text>
            <text class="planet-pinned-arrow">›</text>
          </view>
        </block>

        <view class="planet-feed-card" wx:for="{{latestList}}" wx:key="id" data-id="{{item.id}}" bindtap="onFeedTap">
          <view class="planet-feed-head">
            <view class="planet-feed-avatar {{!item.avatarUrl ? item.avatarClass : ''}} {{!item.avatarUrl ? 'planet-feed-avatar-fallback' : ''}}">
              <image
                wx:if="{{item.avatarUrl}}"
                class="planet-feed-avatar-image"
                src="{{item.avatarUrl}}"
                mode="aspectFill"
                data-list="latestList"
                data-id="{{item.id}}"
                binderror="onFeedAvatarError"
              ></image>
              <text wx:else class="planet-feed-avatar-fallback-text">mo</text>
            </view>
            <view class="planet-feed-author">
              <view class="planet-feed-name-row">
                <text class="planet-feed-name">{{item.author}}</text>
                <text wx:if="{{item.isPinned}}" class="planet-feed-status-tag">置顶</text>
                <text wx:if="{{item.isEssence}}" class="planet-feed-status-tag planet-feed-status-tag-essence">精华</text>
              </view>
              <text class="planet-feed-time">{{item.time}}</text>
            </view>
            <view
              class="planet-feed-manage"
              catchtap="onToggleFeedMenu"
              data-id="{{item.id}}"
              data-is-essence="{{item.isEssence}}"
              data-is-pinned="{{item.isPinned}}"
            >
              <view class="planet-feed-manage-caret {{activeMenuPostId === item.id ? 'planet-feed-manage-caret-active' : ''}}"></view>
              <view wx:if="{{activeMenuPostId === item.id}}" class="planet-feed-menu-panel" catchtap="onFeedMenuPanelTap">
                <view
                  class="planet-feed-menu-item {{action.danger ? 'planet-feed-menu-item-danger' : ''}}"
                  wx:for="{{feedManageActions}}"
                  wx:for-item="action"
                  wx:key="key"
                  catchtap="onFeedManageActionTap"
                  data-key="{{action.key}}"
                  data-id="{{item.id}}"
                  data-is-essence="{{item.isEssence}}"
                  data-is-pinned="{{item.isPinned}}"
                >
                  {{action.label}}
                </view>
              </view>
            </view>
          </view>
          <text class="planet-feed-title">{{item.title}}</text>
          <view wx:if="{{item.columnTitle}}" class="planet-feed-column-tag">
            <text class="planet-feed-column-tag-text">专栏 {{item.columnTitle}}</text>
          </view>
          <view wx:if="{{item.images.length}}" class="planet-feed-images">
            <image wx:for="{{item.displayImages}}" wx:key="*this" class="planet-feed-image" src="{{item}}" mode="aspectFill" lazy-load="true"></image>
          </view>
          <view class="planet-feed-bar">
            <view class="planet-feed-action">
              <view class="feed-icon-like"></view>
              <text>{{item.likeCount}}</text>
            </view>
            <view class="planet-feed-action">
              <view class="feed-icon-comment"></view>
              <text>{{item.commentCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'featured'}}" class="planet-feed-list">
        <view class="planet-feed-card" wx:for="{{featuredList}}" wx:key="id" data-id="{{item.id}}" bindtap="onFeedTap">
          <view class="planet-feed-head">
            <view class="planet-feed-avatar {{!item.avatarUrl ? item.avatarClass : ''}} {{!item.avatarUrl ? 'planet-feed-avatar-fallback' : ''}}">
              <image
                wx:if="{{item.avatarUrl}}"
                class="planet-feed-avatar-image"
                src="{{item.avatarUrl}}"
                mode="aspectFill"
                data-list="featuredList"
                data-id="{{item.id}}"
                binderror="onFeedAvatarError"
              ></image>
              <text wx:else class="planet-feed-avatar-fallback-text">mo</text>
            </view>
            <view class="planet-feed-author">
              <view class="planet-feed-name-row">
                <text class="planet-feed-name">{{item.author}}</text>
                <text wx:if="{{item.isPinned}}" class="planet-feed-status-tag">置顶</text>
                <text wx:if="{{item.isEssence}}" class="planet-feed-status-tag planet-feed-status-tag-essence">精华</text>
              </view>
              <text class="planet-feed-time">{{item.time}}</text>
            </view>
            <view
              class="planet-feed-manage"
              catchtap="onToggleFeedMenu"
              data-id="{{item.id}}"
              data-is-essence="{{item.isEssence}}"
              data-is-pinned="{{item.isPinned}}"
            >
              <view class="planet-feed-manage-caret {{activeMenuPostId === item.id ? 'planet-feed-manage-caret-active' : ''}}"></view>
              <view wx:if="{{activeMenuPostId === item.id}}" class="planet-feed-menu-panel" catchtap="onFeedMenuPanelTap">
                <view
                  class="planet-feed-menu-item {{action.danger ? 'planet-feed-menu-item-danger' : ''}}"
                  wx:for="{{feedManageActions}}"
                  wx:for-item="action"
                  wx:key="key"
                  catchtap="onFeedManageActionTap"
                  data-key="{{action.key}}"
                  data-id="{{item.id}}"
                  data-is-essence="{{item.isEssence}}"
                  data-is-pinned="{{item.isPinned}}"
                >
                  {{action.label}}
                </view>
              </view>
            </view>
          </view>
          <text class="planet-feed-title">{{item.title}}</text>
          <view wx:if="{{item.columnTitle}}" class="planet-feed-column-tag">
            <text class="planet-feed-column-tag-text">专栏 {{item.columnTitle}}</text>
          </view>
          <view class="planet-feed-bar">
            <view class="planet-feed-action">
              <view class="feed-icon-like"></view>
              <text>{{item.likeCount}}</text>
            </view>
            <view class="planet-feed-action">
              <view class="feed-icon-comment"></view>
              <text>{{item.commentCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'files'}}" class="planet-feed-list">
        <view class="planet-feed-card" wx:for="{{fileList}}" wx:key="id" data-id="{{item.id}}" bindtap="onFeedTap">
          <view class="planet-feed-head">
            <view class="planet-feed-avatar {{!item.avatarUrl ? item.avatarClass : ''}} {{!item.avatarUrl ? 'planet-feed-avatar-fallback' : ''}}">
              <image
                wx:if="{{item.avatarUrl}}"
                class="planet-feed-avatar-image"
                src="{{item.avatarUrl}}"
                mode="aspectFill"
                data-list="fileList"
                data-id="{{item.id}}"
                binderror="onFeedAvatarError"
              ></image>
              <text wx:else class="planet-feed-avatar-fallback-text">mo</text>
            </view>
            <view class="planet-feed-author">
              <view class="planet-feed-name-row">
                <text class="planet-feed-name">{{item.author}}</text>
                <text wx:if="{{item.isPinned}}" class="planet-feed-status-tag">置顶</text>
                <text wx:if="{{item.isEssence}}" class="planet-feed-status-tag planet-feed-status-tag-essence">精华</text>
              </view>
              <text class="planet-feed-time">{{item.time}}</text>
            </view>
            <view
              class="planet-feed-manage"
              catchtap="onToggleFeedMenu"
              data-id="{{item.id}}"
              data-is-essence="{{item.isEssence}}"
              data-is-pinned="{{item.isPinned}}"
            >
              <view class="planet-feed-manage-caret {{activeMenuPostId === item.id ? 'planet-feed-manage-caret-active' : ''}}"></view>
              <view wx:if="{{activeMenuPostId === item.id}}" class="planet-feed-menu-panel" catchtap="onFeedMenuPanelTap">
                <view
                  class="planet-feed-menu-item {{action.danger ? 'planet-feed-menu-item-danger' : ''}}"
                  wx:for="{{feedManageActions}}"
                  wx:for-item="action"
                  wx:key="key"
                  catchtap="onFeedManageActionTap"
                  data-key="{{action.key}}"
                  data-id="{{item.id}}"
                  data-is-essence="{{item.isEssence}}"
                  data-is-pinned="{{item.isPinned}}"
                >
                  {{action.label}}
                </view>
              </view>
            </view>
          </view>
          <text class="planet-feed-title">{{item.title}}</text>
          <view wx:if="{{item.columnTitle}}" class="planet-feed-column-tag">
            <text class="planet-feed-column-tag-text">专栏 {{item.columnTitle}}</text>
          </view>
          <view wx:if="{{item.images.length}}" class="planet-feed-images">
            <image wx:for="{{item.displayImages}}" wx:key="*this" class="planet-feed-image" src="{{item}}" mode="aspectFill" lazy-load="true"></image>
          </view>
          <view wx:elif="{{item.hasFile}}" class="planet-file-box">
            <view class="planet-file-icon">文件</view>
            <view class="planet-file-copy">
              <text class="planet-file-name">{{item.fileName}}</text>
              <text wx:if="{{item.fileSizeText}}" class="planet-file-meta">{{item.fileSizeText}}</text>
            </view>
          </view>
          <view class="planet-feed-bar">
            <view class="planet-feed-action">
              <view class="feed-icon-like"></view>
              <text>{{item.likeCount}}</text>
            </view>
            <view class="planet-feed-action">
              <view class="feed-icon-comment"></view>
              <text>{{item.commentCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'answer' && answerList.length}}" class="planet-feed-list">
        <view class="planet-feed-card" wx:for="{{answerList}}" wx:key="id" data-id="{{item.id}}" bindtap="onFeedTap">
          <view class="planet-feed-head">
            <view class="planet-feed-avatar {{!item.avatarUrl ? item.avatarClass : ''}} {{!item.avatarUrl ? 'planet-feed-avatar-fallback' : ''}}">
              <image
                wx:if="{{item.avatarUrl}}"
                class="planet-feed-avatar-image"
                src="{{item.avatarUrl}}"
                mode="aspectFill"
                data-list="answerList"
                data-id="{{item.id}}"
                binderror="onFeedAvatarError"
              ></image>
              <text wx:else class="planet-feed-avatar-fallback-text">mo</text>
            </view>
            <view class="planet-feed-author">
              <view class="planet-feed-name-row">
                <text class="planet-feed-name">{{item.author}}</text>
                <text wx:if="{{item.isPinned}}" class="planet-feed-status-tag">置顶</text>
                <text wx:if="{{item.isEssence}}" class="planet-feed-status-tag planet-feed-status-tag-essence">精华</text>
              </view>
              <text class="planet-feed-time">{{item.time}}</text>
            </view>
            <view
              class="planet-feed-manage"
              catchtap="onToggleFeedMenu"
              data-id="{{item.id}}"
              data-is-essence="{{item.isEssence}}"
              data-is-pinned="{{item.isPinned}}"
            >
              <view class="planet-feed-manage-caret {{activeMenuPostId === item.id ? 'planet-feed-manage-caret-active' : ''}}"></view>
              <view wx:if="{{activeMenuPostId === item.id}}" class="planet-feed-menu-panel" catchtap="onFeedMenuPanelTap">
                <view
                  class="planet-feed-menu-item {{action.danger ? 'planet-feed-menu-item-danger' : ''}}"
                  wx:for="{{feedManageActions}}"
                  wx:for-item="action"
                  wx:key="key"
                  catchtap="onFeedManageActionTap"
                  data-key="{{action.key}}"
                  data-id="{{item.id}}"
                  data-is-essence="{{item.isEssence}}"
                  data-is-pinned="{{item.isPinned}}"
                >
                  {{action.label}}
                </view>
              </view>
            </view>
          </view>
          <text class="planet-feed-title">{{item.title}}</text>
          <view wx:if="{{item.columnTitle}}" class="planet-feed-column-tag">
            <text class="planet-feed-column-tag-text">专栏 {{item.columnTitle}}</text>
          </view>
          <view class="planet-feed-bar">
            <view class="planet-feed-action">
              <view class="feed-icon-like"></view>
              <text>{{item.likeCount}}</text>
            </view>
            <view class="planet-feed-action">
              <view class="feed-icon-comment"></view>
              <text>{{item.commentCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{activeTab === 'answer' && !answerList.length}}" class="planet-empty-answer">
        <text class="planet-empty-text">这里空空如也</text>
      </view>
    </view>
  </scroll-view>

  <view class="planet-publish-fab" hover-class="planet-publish-fab-active" bindtap="onPublish">
    <view class="planet-publish-button">
      <view class="planet-publish-pen"></view>
    </view>
  </view>

  <view wx:if="{{publishMenuVisible}}" class="planet-publish-mask" bindtap="onClosePublishMenu">
    <view class="planet-publish-panel" catchtap="onPublishPanelTap">
      <view
        class="planet-publish-option"
        wx:for="{{publishActions}}"
        wx:key="key"
        data-type="{{item.key}}"
        bindtap="onPublishOptionTap"
      >
        <view class="planet-publish-option-icon {{item.iconClass}}"></view>
        <view class="planet-publish-option-copy">
          <text class="planet-publish-option-label">{{item.label}}</text>
          <text class="planet-publish-option-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{columnPickerVisible}}" class="planet-column-picker-mask" bindtap="onCloseColumnPicker">
    <view class="planet-column-picker-sheet" catchtap="onColumnPickerPanelTap">
      <view class="planet-column-picker-handle"></view>
      <view class="planet-column-picker-head">
        <text class="planet-column-picker-title">归类到专栏</text>
        <text class="planet-column-picker-close" bindtap="onCloseColumnPicker">取消</text>
      </view>
      <text class="planet-column-picker-desc">为“{{columnPickerPostTitle}}”选择一个专栏目录，方便后续统一沉淀。</text>

      <view wx:if="{{columnPickerLoading}}" class="planet-column-picker-loading">
        <text class="planet-column-picker-loading-text">专栏加载中...</text>
      </view>

      <view wx:elif="{{columnPickerColumns.length}}" class="planet-column-picker-list">
        <view class="planet-column-picker-item planet-column-picker-item-clear" bindtap="onSelectPostColumn" data-column-id="">
          <view class="planet-column-picker-copy">
            <text class="planet-column-picker-name">不归类到任何专栏</text>
            <text class="planet-column-picker-meta">让这条帖子继续留在公共主题流里</text>
          </view>
          <text wx:if="{{!columnPickerCurrentColumnId}}" class="planet-column-picker-check">当前</text>
        </view>

        <view
          wx:for="{{columnPickerColumns}}"
          wx:key="id"
          class="planet-column-picker-item {{item.isCurrent ? 'planet-column-picker-item-active' : ''}}"
          bindtap="onSelectPostColumn"
          data-column-id="{{item.id}}"
        >
          <view class="planet-column-picker-copy">
            <text class="planet-column-picker-name">{{item.title}}</text>
            <text class="planet-column-picker-meta">{{item.count}} 篇内容</text>
          </view>
          <text wx:if="{{item.isCurrent}}" class="planet-column-picker-check">当前</text>
        </view>
      </view>

      <view wx:else class="planet-column-picker-empty">
        <text class="planet-column-picker-empty-text">这个星球还没有专栏，先去“专栏”页创建一个吧</text>
      </view>
    </view>
  </view>
</block>

<block wx:else>
  <scroll-view class="planet-detail-page" scroll-y="{{true}}">
    <view class="planet-detail-shell">
      <view class="planet-summary-card">
        <view class="planet-summary-head">
          <view class="planet-summary-copy">
            <text class="planet-summary-name">{{planetName}}</text>
            <text class="planet-summary-no">星球号：{{planetNo}}</text>
            <view class="planet-summary-tags">
              <view
                class="planet-summary-tag {{index === 0 ? 'planet-summary-tag-verified' : ''}}"
                wx:for="{{tags}}"
                wx:key="index"
              >
                {{item}}
              </view>
            </view>
          </view>
          <view class="planet-summary-avatar planet-avatar-frame {{avatarClass}}">
            <image wx:if="{{avatarImageUrl}}" class="planet-summary-avatar-image" src="{{avatarImageUrl}}" mode="aspectFill"></image>
            <text wx:else class="planet-summary-avatar-text">{{planetName.slice(0, 1) || '星'}}</text>
          </view>
        </view>

        <view class="planet-summary-metrics">
          <view class="planet-summary-metric" wx:for="{{metrics}}" wx:key="label">
            <text class="planet-summary-metric-value">{{item.value}}</text>
            <text class="planet-summary-metric-label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="planet-section">
        <view class="planet-section-head">
          <text class="planet-section-title">星球介绍</text>
          <text class="planet-section-side">{{reportLabel}}</text>
        </view>

        <view class="planet-owner-card" bindtap="onOwnerTap">
          <view class="planet-owner-avatar">
            <image wx:if="{{ownerAvatarImageUrl}}" class="planet-owner-avatar-image" src="{{ownerAvatarImageUrl}}" mode="aspectFill"></image>
            <text wx:else class="planet-owner-avatar-text">{{ownerName.slice(0, 1) || '主'}}</text>
          </view>
          <view class="planet-owner-copy">
            <text class="planet-owner-name">星主：#{{ownerName}}</text>
            <text class="planet-owner-active">{{ownerActiveText}}</text>
          </view>
        </view>

        <view class="planet-description">
          <text class="planet-description-text" wx:for="{{previewDescriptionList}}" wx:key="index">
            {{item}}
          </text>
        </view>

        <text class="planet-expand-link" bindtap="onToggleIntro">
          {{introExpanded ? '收起' : '点击展开'}}
        </text>
      </view>

      <view wx:if="{{paywallHighlights.length}}" class="planet-section">
        <view class="planet-section-head">
          <text class="planet-section-title">星球亮点</text>
          <text class="planet-section-side">{{paywallHighlights.length}}张</text>
        </view>

        <view class="planet-highlight-grid">
          <view
            wx:for="{{paywallHighlights}}"
            wx:key="url"
            class="planet-highlight-card"
            data-url="{{item.url}}"
            bindtap="onPaywallHighlightTap"
          >
            <view class="planet-highlight-standee">
              <view class="planet-highlight-board">
                <view class="planet-highlight-paper">
                  <image class="planet-highlight-image" src="{{item.displayUrl}}" mode="aspectFit" lazy-load="true"></image>
                </view>
                <view class="planet-highlight-sheen"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{showRenewalEntry}}" class="planet-section">
        <view class="planet-section-head">
          <text class="planet-section-title">成员续期</text>
          <text class="planet-section-side">{{renewalBadgeText}}</text>
        </view>

        <view class="planet-renewal-card">
          <view class="planet-renewal-copy">
            <text class="planet-renewal-title">{{renewalTitle}}</text>
            <text class="planet-renewal-hint">{{renewalHint}}</text>
            <view class="planet-renewal-price-row">
              <text class="planet-renewal-price">{{renewalPriceText}}</text>
              <text wx:if="{{renewalOriginalPriceText}}" class="planet-renewal-original">{{renewalOriginalPriceText}}</text>
              <text wx:if="{{renewalDiscountText}}" class="planet-renewal-discount">{{renewalDiscountText}}</text>
            </view>
          </view>
          <button class="planet-renewal-button" loading="{{joinLoading}}" disabled="{{joinLoading}}" bindtap="onRenewTap">{{renewalActionText}}</button>
        </view>
      </view>

      <view class="planet-section">
        <view class="planet-section-head">
          <text class="planet-section-title">付费须知</text>
        </view>

        <view class="planet-rules">
          <view class="planet-rule-item" wx:for="{{feeNotices}}" wx:key="index">
            <text class="planet-rule-index">{{index + 1}}.</text>
            <text class="planet-rule-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!isJoined && !showRenewalEntry && priceText !== '免费'}}" class="planet-section">
        <view class="planet-section-head">
          <text class="planet-section-title">优惠券</text>
          <text class="planet-section-side">{{joinCouponLoading ? '加载中' : joinCouponSummary}}</text>
        </view>

        <view wx:if="{{joinCoupons.length}}" class="planet-coupon-list">
          <view
            wx:for="{{joinCoupons}}"
            wx:key="code"
            class="planet-coupon-card {{item.selected ? 'planet-coupon-card-selected' : ''}}"
            data-code="{{item.code}}"
            bindtap="onCouponTap"
          >
            <view class="planet-coupon-copy">
              <view class="planet-coupon-title-row">
                <text class="planet-coupon-title">{{item.name}}</text>
                <text wx:if="{{item.isRecommended}}" class="planet-coupon-tag">推荐</text>
              </view>
              <text class="planet-coupon-meta">
                {{item.remainingQuantity !== null ? '剩余 ' + item.remainingQuantity + ' 张' : '库存充足'}} · 截止 {{item.validTo}}
              </text>
            </view>
            <view class="planet-coupon-amount">
              <text class="planet-coupon-amount-value">{{item.amountText}}</text>
              <text class="planet-coupon-action">{{item.selected ? '已选中' : '点击使用'}}</text>
            </view>
          </view>
        </view>

        <view wx:elif="{{!joinCouponLoading}}" class="planet-coupon-empty">
          <text class="planet-coupon-empty-text">当前没有可直接使用的拉新券，管理端新建并生效后，这里会自动接上。</text>
        </view>
      </view>

      <view class="planet-section">
        <view class="planet-section-head">
          <text class="planet-section-title">部分主题预览</text>
        </view>

        <view wx:if="{{allowPreview && previewList.length}}" class="planet-preview-list">
          <view
            class="planet-preview-item"
            wx:for="{{previewList}}"
            wx:key="id"
            data-post-id="{{item.targetPostId}}"
            bindtap="onPreviewTap"
          >
            <view class="planet-preview-author">
              <image class="planet-preview-author-avatar" src="{{item.authorAvatar}}" mode="aspectFill"></image>
              <view class="planet-preview-author-copy">
                <text class="planet-preview-author-name">{{item.author}}</text>
                <text class="planet-preview-author-time">{{item.time}}</text>
              </view>
            </view>

            <text class="planet-preview-title">{{item.title}}</text>
            <text class="planet-preview-summary">{{item.summary}}</text>
            <image wx:if="{{item.image}}" class="planet-preview-image" src="{{item.image}}" mode="aspectFill"></image>
          </view>
        </view>

        <view wx:else class="planet-preview-locked">
          <text class="planet-preview-locked-title">{{allowPreview ? '当前还没有可预览的主题' : '当前星球不开放预览'}}</text>
          <text class="planet-preview-locked-text">
            {{allowPreview ? '后续有公开样本后，会在这里展示部分主题内容。' : '只有正式加入后，才能查看完整主题与互动内容。'}}
          </text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="planet-join-bar">
    <view wx:if="{{showRenewalEntry}}" class="planet-join-summary">
      <view class="planet-join-summary-copy">
        <text class="planet-join-summary-label">{{renewalSummaryLabel}}</text>
        <text class="planet-join-summary-price">{{renewalPriceText}}</text>
      </view>
      <text class="planet-join-summary-hint">{{renewalSummaryHint}}</text>
    </view>

    <view wx:elif="{{!isJoined && priceText !== '免费'}}" class="planet-join-summary">
      <view class="planet-join-summary-copy">
        <text class="planet-join-summary-label">应付金额</text>
        <text class="planet-join-summary-price">{{displayPriceText}}</text>
      </view>
      <text wx:if="{{selectedCouponName}}" class="planet-join-summary-hint">
        {{selectedCouponName}} 已抵扣 {{selectedCouponAmountText}}
      </text>
      <text wx:elif="{{priceText !== displayPriceText}}" class="planet-join-summary-hint">已自动应用最优优惠券</text>
      <text wx:else class="planet-join-summary-hint">原价 {{priceText}}</text>
    </view>

    <button wx:if="{{showRenewalEntry}}" class="planet-join-button" loading="{{joinLoading}}" disabled="{{joinLoading}}" bindtap="onRenewTap">
      {{renewalActionText}}
    </button>

    <button
      wx:else
      class="planet-join-button {{joinButtonDisabled ? 'planet-join-button-disabled' : ''}}"
      loading="{{joinLoading}}"
      disabled="{{joinButtonDisabled}}"
      bindtap="onJoinTap"
    >
      {{joinButtonText}}
    </button>
  </view>
</block>
