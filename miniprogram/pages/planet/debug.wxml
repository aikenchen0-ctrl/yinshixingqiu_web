<navigation-bar
  title="调试"
  back="{{false}}"
  back-url="/pages/planet/index"
  color="#16212f"
  background="#ffffff"
></navigation-bar>

<view class="page planet-debug-page">
  <view class="planet-debug-shell">
    <view class="planet-debug-card planet-debug-summary-card">
      <text class="planet-debug-card-title">当前调试环境</text>
      <view class="planet-debug-summary-row">
        <text class="planet-debug-summary-label">服务地址</text>
        <text class="planet-debug-summary-value">{{activeBaseUrl}}</text>
      </view>
      <view class="planet-debug-summary-row">
        <text class="planet-debug-summary-label">当前用户</text>
        <text class="planet-debug-summary-value">{{sessionNickname}}</text>
      </view>
      <view class="planet-debug-summary-row">
        <text class="planet-debug-summary-label">手机号</text>
        <text class="planet-debug-summary-value">{{sessionMobile}}</text>
      </view>
      <view class="planet-debug-summary-row">
        <text class="planet-debug-summary-label">Session</text>
        <text class="planet-debug-summary-token">{{sessionTokenDisplay}}</text>
      </view>
    </view>

    <view class="planet-debug-card">
      <text class="planet-debug-card-title">调试动作</text>
      <view class="planet-debug-action-list">
        <view
          class="planet-debug-action-item"
          wx:for="{{actions}}"
          wx:key="id"
        >
          <view class="planet-debug-action-copy">
            <text class="planet-debug-action-title">{{item.title}}</text>
            <text class="planet-debug-action-desc">{{item.desc}}</text>
          </view>
          <button
            class="planet-debug-action-button"
            data-action="{{item.id}}"
            loading="{{loadingAction === item.id}}"
            bindtap="onActionTap"
          >
            运行
          </button>
        </view>
      </view>
    </view>

    <view class="planet-debug-card planet-debug-response-card">
      <view class="planet-debug-response-header">
        <text class="planet-debug-card-title planet-debug-response-title">{{responseTitle}}</text>
        <button class="planet-debug-copy-button" bindtap="onCopyResponse">复制接口返回</button>
      </view>
      <scroll-view class="planet-debug-response-scroll" scroll-y>
        <text selectable class="planet-debug-response-text">{{responseText}}</text>
      </scroll-view>
    </view>
  </view>

  <planet-bottom-nav active-key="debug" bindchange="onPlanetTabChange"></planet-bottom-nav>
</view>
