<navigation-bar
  title="知识星球"
  back="{{true}}"
  color="#111111"
  background="#ffffff"
></navigation-bar>

<view class="page share-card-page">
  <view class="share-card-shell">
    <view class="share-card-poster">
      <view class="share-card-cover-wrap">
        <image class="share-card-cover" src="{{planet.coverImageUrl}}" mode="aspectFill"></image>
        <view class="share-card-cover-mask"></view>
        <view class="share-card-center">
          <image class="share-card-avatar" src="{{planet.avatarImageUrl}}" mode="aspectFill"></image>
          <text class="share-card-name">{{planet.name}}</text>
          <text class="share-card-owner">{{displayOwnerName}}</text>
        </view>
      </view>

      <view class="share-card-footer">
        <view class="share-card-brand">
          <view class="share-card-brand-icon"></view>
          <view class="share-card-brand-copy">
            <text class="share-card-brand-name">知识星球</text>
            <text class="share-card-brand-desc">连接一千位铁杆粉丝</text>
          </view>
        </view>

        <view class="share-card-qrcode">
          <view class="share-card-qrcode-ring"></view>
          <view class="share-card-qrcode-center"></view>
          <view class="share-card-qrcode-corner share-card-qrcode-corner-left"></view>
          <view class="share-card-qrcode-corner share-card-qrcode-corner-top"></view>
          <view class="share-card-qrcode-corner share-card-qrcode-corner-right"></view>
          <view class="share-card-qrcode-dot share-card-qrcode-dot-a"></view>
          <view class="share-card-qrcode-dot share-card-qrcode-dot-b"></view>
          <view class="share-card-qrcode-dot share-card-qrcode-dot-c"></view>
          <view class="share-card-qrcode-dot share-card-qrcode-dot-d"></view>
          <view class="share-card-qrcode-dot share-card-qrcode-dot-e"></view>
          <view class="share-card-qrcode-dot share-card-qrcode-dot-f"></view>
          <view class="share-card-qrcode-mini"></view>
        </view>
      </view>
    </view>

    <button class="share-card-save-button" bindtap="onSavePoster">保存图片</button>
  </view>

  <canvas
    class="share-card-canvas"
    canvas-id="sharePosterCanvas"
    id="sharePosterCanvas"
    type="2d"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
  ></canvas>
</view>
