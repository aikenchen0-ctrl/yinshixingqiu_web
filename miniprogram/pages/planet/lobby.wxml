<navigation-bar
  title="发现"
  back="{{false}}"
  back-url="/pages/planet/index"
  color="#2c1a0d"
  background="#ffffff"
></navigation-bar>

<view class="page discover-page">
  <view class="discover-shell">
    <view class="discover-section">
      <view class="section-heading">
        <text class="section-title">你可能感兴趣</text>
        <view class="section-action" bindtap="onRefreshInterest">
          <text class="section-action-icon">↻</text>
          <text class="section-action-text">换一批</text>
        </view>
      </view>

      <view wx:if="{{interestList.length}}" class="interest-list">
        <view
          class="interest-item"
          wx:for="{{interestList}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-creator="{{item.creator}}"
          bindtap="onPlanetTap"
        >
          <image class="interest-cover" src="{{item.image}}" mode="aspectFill"></image>
          <view class="interest-copy">
            <text class="interest-name">{{item.name}}</text>
            <text class="interest-meta">{{item.meta}}</text>
            <text class="interest-summary">{{item.summary}}</text>
          </view>
        </view>
      </view>
      <view wx:elif="{{loadingInterest}}" class="section-empty">
        <text class="section-empty-text">正在拉取真实星球...</text>
      </view>
      <view wx:else class="section-empty">
        <text class="section-empty-text">{{interestStatusText || '还没有其他用户创建可推荐的真实星球'}}</text>
      </view>
    </view>

    <view class="discover-section">
      <view class="section-heading">
        <text class="section-title">精华主题</text>
        <view class="section-action" bindtap="onRefreshFeatured">
          <text class="section-action-icon">↻</text>
          <text class="section-action-text">换一批</text>
        </view>
      </view>

      <view wx:if="{{featuredList.length}}" class="topic-list">
        <view
          class="topic-item"
          wx:for="{{featuredList}}"
          wx:key="id"
          data-post-id="{{item.postId}}"
          data-planet-id="{{item.planetId}}"
          bindtap="onTopicTap"
        >
          <view class="topic-main {{item.cover ? 'topic-main-with-cover' : ''}}">
            <view class="topic-copy">
              <text class="topic-title">{{item.title}}</text>
              <text class="topic-summary">{{item.summary}}</text>
              <text class="topic-meta">{{item.author}}｜{{item.meta}}</text>
            </view>
            <image
              wx:if="{{item.cover}}"
              class="topic-cover"
              src="{{item.cover}}"
              mode="aspectFill"
            ></image>
          </view>
        </view>
      </view>
      <view wx:elif="{{loadingFeatured}}" class="section-empty">
        <text class="section-empty-text">正在拉取真实精华主题...</text>
      </view>
      <view wx:else class="section-empty">
        <text class="section-empty-text">{{featuredStatusText || '还没有可推荐的其他星球精华主题'}}</text>
      </view>
    </view>
  </view>

  <planet-bottom-nav active-key="discover" bindchange="onPlanetTabChange"></planet-bottom-nav>
</view>
