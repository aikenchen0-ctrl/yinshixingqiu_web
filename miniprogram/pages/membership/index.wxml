<navigation-bar
  title="会员制"
  back="{{true}}"
  color="#e6f0ff"
  background="rgba(10, 18, 32, 0.96)"
></navigation-bar>

<view class="page grid-bg">
    <view class="section card membership-hero">
      <text class="membership-title">{{headerTitle}}</text>
      <text class="membership-sub">{{headerSubtitle}}</text>
    </view>

    <view wx:if="{{fromMall}}" class="section card membership-context-card">
      <view class="section-title">商城承接</view>
      <text class="membership-context-title">{{contextTitle}}</text>
      <text class="membership-context-desc">{{contextDesc}}</text>
      <button class="btn membership-context-button" bindtap="onContinueStore">先回商城看看</button>
    </view>

    <view class="section card">
      <view class="section-title">选择方案</view>
      <view class="plan-list">
        <view
          class="plan-card {{selectedPlan === item.id ? 'plan-active' : ''}}"
          wx:for="{{plans}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onSelectPlan"
        >
          <text class="plan-title">{{item.title}}</text>
          <text class="plan-price">{{item.price}}</text>
          <text class="plan-desc">{{item.desc}}</text>
        </view>
      </view>
      <button class="btn btn-warn pay-button" bindtap="onPay">{{payButtonText}}</button>
    </view>

    <view class="section card">
      <view class="section-title">会员权益</view>
      <view class="benefit-list">
        <view class="benefit-item" wx:for="{{benefits}}" wx:key="id">
          <view class="benefit-dot"></view>
          <text class="benefit-text">{{item}}</text>
        </view>
      </view>
    </view>

  <view class="section safe-bottom"></view>
</view>
