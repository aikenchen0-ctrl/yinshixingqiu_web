<navigation-bar
  title=""
  back="{{true}}"
  color="#22160d"
  background="#ffffff"
></navigation-bar>

<view class="auth-page" style="min-height: calc(100vh - {{navOffset}}px);">
  <view class="auth-shell">
    <view class="auth-profile-card">
      <view class="auth-hero">
        <view class="auth-ring ring-outer"></view>
        <view class="auth-ring ring-middle"></view>
        <view class="auth-ring ring-inner"></view>
        <view class="auth-avatar auth-avatar-fallback">
          <text class="auth-avatar-fallback-text">{{heroMark}}</text>
        </view>
      </view>

      <text class="auth-badge">{{sceneBadge}}</text>
      <text class="auth-title">{{sceneTitle}}</text>
      <text class="auth-subtitle">{{sceneSubtitle}}</text>

      <view class="auth-login-panel">
        <text class="auth-panel-title">{{panelTitle}}</text>
        <text class="auth-panel-desc">{{panelDesc}}</text>

        <view class="auth-benefit-list">
          <view wx:for="{{benefits}}" wx:key="*this" class="auth-benefit-item">
            <view class="auth-benefit-dot"></view>
            <text class="auth-benefit-text">{{item}}</text>
          </view>
        </view>

        <view class="auth-agreement" bindtap="onToggleAgree">
          <view class="auth-checkbox {{agreeProtocol ? 'is-checked' : ''}}"></view>
          <text class="auth-agreement-text">我已阅读并同意《用户协议》与《隐私政策》</text>
        </view>

        <button
          class="auth-submit"
          loading="{{loading}}"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >
          手机号一键登录
        </button>

        <button class="auth-submit auth-submit-ghost" loading="{{loading}}" bindtap="onSubmit">
          仅刷新微信登录态
        </button>
      </view>
    </view>

    <view class="auth-tip-card">
      <text class="auth-tip-title">{{footerTitle}}</text>
      <text class="auth-tip-desc">{{footerDesc}}</text>
    </view>
  </view>
</view>
