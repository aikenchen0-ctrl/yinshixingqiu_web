<navigation-bar
  title="课程日历"
  back="{{false}}"
  color="#e6f0ff"
  background="rgba(10, 18, 32, 0.96)"
></navigation-bar>

<view class="page grid-bg">
    <view class="section card calendar-card">
      <view class="calendar-header">
        <text class="calendar-title">{{monthLabel}}</text>
        <view class="chip">同步 {{lastSync}}</view>
      </view>
      <view class="week-row">
        <text class="week-day" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="day-grid">
        <view
          class="day-cell {{item.isToday ? 'day-today' : ''}} {{item.hasCourse ? 'day-active' : ''}}"
          wx:for="{{calendarDays}}"
          wx:key="id"
        >
          <text class="day-text">{{item.day}}</text>
          <view wx:if="{{item.hasCourse}}" class="day-dot"></view>
        </view>
      </view>
    </view>

    <view class="section card">
      <view class="section-title">本周课程</view>
      <view class="section-subtitle">支持直播提醒与回放权限</view>
      <view class="session-list">
        <view class="session-card" wx:for="{{sessions}}" wx:key="id">
          <view class="session-left">
            <text class="session-date">{{item.date}}</text>
            <text class="session-time">{{item.time}}</text>
          </view>
          <view class="session-body">
            <text class="session-title">{{item.title}}</text>
            <text class="session-meta">{{item.type}}</text>
          </view>
          <view class="session-action">
            <button class="btn btn-ghost" data-id="{{item.id}}" bindtap="onReminder">提醒</button>
          </view>
        </view>
      </view>
    </view>

  <view class="section safe-bottom"></view>
</view>
